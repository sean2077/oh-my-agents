# Force LF for Go and POSIX shell sources so formatting and lint results are
# byte-identical across the CI OS matrix. Without this, Windows checkouts can
# introduce CRLF even though the committed files are LF.
*.go text eol=lf
*.sh text eol=lf
.agents/*.py text eol=lf
.husky/pre-commit text eol=lf
tools/git-hooks/* text eol=lf
.agents/tools/*.py text eol=lf
.agents/tools/hooks/*.py text eol=lf
